{
  "config": {
    "handlePrefix": "my-asset-handle",
    "host": "localhost",
    "site": "http://localhost:8080",
    "port": "8080",
    "protocol": "http",
    "theme": "theme-name",
    "src": "resources",
    "themePath": "wp-content/themes/"
  },
  "assets": {
    "enqueue_block_editor_assets": [
      {
        "handle": "editor-js",
        "path": "/js/editor",
        "ext": "js"
      }
    ],
    "wp_enqueue_scripts": [
      {
        "path": "/js/screen",
        "ext": "js",
        "condition": ["is_user_logged_in", null, false]
      }
    ]
  }
}
