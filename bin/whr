#!/bin/bash
# shellcheck disable=SC1091
# get script path from vendor dir @see https://getcomposer.org/doc/articles/vendor-binaries.md
if [[ -z "$COMPOSER_RUNTIME_BIN_DIR" ]]; then
	BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
	BIN_DIR="$COMPOSER_RUNTIME_BIN_DIR"
fi
PACKAGE_DIR="${BIN_DIR}/../aslamhus/wordpress-hmr"
export PACKAGE_DIR

source "${PACKAGE_DIR}/bin/wordpress.sh"
source "${PACKAGE_DIR}/bin/utils.sh"
source "${PACKAGE_DIR}/bin/docker.sh"
WORKING_DIR_NAME=$(getWorkingDirectoryName)
WORKING_DIR=$PWD
export WORKING_DIR

main() {
	checkForDocker || exit
	case "$1" in

	"install")
		install
		;;

	"start")
		start "$@"
		;;

	"stop")
		stop
		;;

	"start-docker")
		startDocker
		;;

	"destroy-docker")
		destroyDocker
		;;

	"build")
		build
		;;

	"wp")
		wp "$@"
		;;

	"exec")
		execContainer "$@"
		;;

	"open")
		openDockerInBrowser
		;;
	"create-db")
		createDb
		;;

	esac
}

install() {
	# cd into your project root
	# move the installer
	cp "${PACKAGE_DIR}/installer.php" ./installer.php
	# run the installer
	# "${PACKAGE_DIR}/bin/install.sh"
	php installer.php
	# # cleanup
	rm installer.php
}

# Start
# starts docker and webpack
# TODO: add --hot flag to optionally start webpack
start() {
	echo "starting WHR container..."
	startDocker 'open' || exit 1
	# get the port and start webpack
	startWebpack
}

startDocker() {
	open=$1
	export WHR_PORT=""
	export PHPMYADMIN_PORT=""
	WHR_PORT="$(getWHRJsonPort)"
	# isContainerRunning && docker-compose down
	# cbeck that the port specified in whr.json is available
	if ! isDockerPortAvailable "$WHR_PORT"; then
		if
			! isContainerRunning ||
				(isContainerRunning && [[ "$(getDockerContainerPort)" != "$WHR_PORT" ]])
		then
			echo "❌ Unable to start container, port $WHR_PORT is already in use. You can set a different port in whr.json "
			exit 1
		fi
	fi
	# find an available port for phpmyadmin
	# PHPMYADMIN_PORT="$((WHR_PORT + 1))"
	PHPMYADMIN_PORT="8180"
	if ! isContainerRunning && ! isDockerPortAvailable "$PHPMYADMIN_PORT"; then
		echo "Finding an available port for phpMyAdmin"
		while ! isDockerPortAvailable "$PHPMYADMIN_PORT"; do
			((PHPMYADMIN_PORT++))
		done
	fi
	# start docker container  (to rebuild add --build flag)
	if ! docker-compose up -d --wait; then
		echo "Docker compose failed"
		exit 1
	fi
	# update the wordpress / whr.json port if necessary
	setWHRPort "$WHR_PORT"
	echo "✔️ Starting container: $(getDockerContainerName "wordpress")"
	echo "✔️ phpMyAdmin started at http://localhost:${PHPMYADMIN_PORT}"
	echo "✔️ Wordpress started at http://localhost:${WHR_PORT}"
	# optionally, open in web browser
	[[ -n "$open" ]] && open "http://localhost:${WHR_PORT}"
}

startWebpack() {
	(
		cd "${PACKAGE_DIR}" || exit
		# enable webpack to access WORKING_DIR global
		export WORKING_DIR="$WORKING_DIR"
		npx webpack serve --config ./build/webpack.dev.js
	)
}

stop() {
	docker-compose down
}

openDockerInBrowser() {
	local port=""
	echo 'open please'
	port="$(getPort)"
	open "http://localhost:${port}"
}

createDb() {
	local url
	local title
	url="localhost:$(getPort)"
	title="$WORKING_DIR_NAME"
	echo "wp core install --url=$url --title=$title --admin_user='admin' --admin_password='password' --admin_email='admin@example.com'"

	if ! main wp core install --url="$url" --title="$title" --admin_user='admin' --admin_email='admin@example.com' --admin_password='password'; then
		echo "Failed to run wp core install"
		return 1
	fi

	echo "Wordpress site installed"

}

build() {
	# 1. Build wp scripts asset files in public diretory
	buildWebpack
	# 2. Build enqueue assets
	buildEnqueueAssets
}

# Build webpack
# !!!Remember, this is running in your project directory, outside container
# but it outputs to the volume inside the container
buildWebpack() {
	cd vendor/aslamhus/wordpress-hmr || exit 1
	npx wp-scripts build --webpack-src-dir="$WORKING_DIR/resources" --config build/webpack.prod.js
	cd "$WORKING_DIR"
}

# Build Enqueue Assets
# !!!Remember, you are running this command inside the wordpress container
buildEnqueueAssets() {
	execContainer wordpress bash -c "
		cd ../vendor/aslamhus/wordpress-hmr
		php build.php"
}

# run wp-cli in docker container
wp() {
	shift
	container=$(getDockerContainerName wpcli)
	[[ -z "$container" ]] && (
		echo "Failed to run wp-cli. Container name not found. Please start your container"
		exit 1
	)

	docker exec "${container}" wp "$@"
}

# execute commands in the wordpress container
execContainer() {
	shift
	container=$(getDockerContainerName wordpress)
	[[ -z "$container" ]] && (
		echo "Failed to run docker exec. Container name not found. Please start your container"
		exit 1
	)
	docker exec "${container}" "$@"
}

destroyDocker() {
	docker compose down --rmi all --volumes
}

main "$@"
