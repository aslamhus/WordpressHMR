#!/bin/bash
# shellcheck disable=SC1091
# get script path from vendor dir @see https://getcomposer.org/doc/articles/vendor-binaries.md
if [[ -z "$COMPOSER_RUNTIME_BIN_DIR" ]]; then
	BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
	BIN_DIR="$COMPOSER_RUNTIME_BIN_DIR"
fi
PACKAGE_DIR="${BIN_DIR}/../aslamhus/wordpress-hmr"
export PACKAGE_DIR
source "${PACKAGE_DIR}/bin/wordpress.sh"
source "${PACKAGE_DIR}/bin/utils.sh"
source "${PACKAGE_DIR}/bin/docker.sh"
WORKING_DIR_NAME=$(getWorkingDirectoryName)
WORKING_DIR=$PWD
export WORKING_DIR

main() {
	checkForDocker || exit
	case "$1" in

	"install")
		install
		;;

	"start")
		start "$@"
		;;

	"stop")
		stop
		;;

	"start-docker")
		startDocker
		;;

	"clean")
		clean
		;;

	"destroy")
		destroy
		;;

	"build")
		build
		;;

	"wp")
		wp "$@"
		;;

	"exec")
		execContainer "$@"
		;;

	"open")
		openDockerInBrowser
		;;
	"core-install")
		coreInstall
		;;
	"create-child-theme")
		createChildTheme
		;;

	esac
}

install() {
	php "${PACKAGE_DIR}/installer.php"
}

createChildTheme() {
	php "${PACKAGE_DIR}/installer.php" --scaffold-child
}

# Start
# starts docker and webpack
start() {
	h=false
	o=false
	r=false
	shift
	while [[ $# -gt 0 ]]; do
		arg="$1"
		case "$1" in
		# start webpack hot module replacement
		'--hot')
			h=true
			;;
		# open in browser
		'--open')
			o=true
			;;
		# wipe database and reinstall core
		'--reset')
			r=true
			;;
		*)
			printStartUsage
			exit 1
			;;
		esac
		shift
	done
	export WHR_PORT=""
	export PHPMYADMIN_PORT=""
	if ! "${r}"; then
		startDocker || exit 1
	else
		reset
		startDocker --build || exit 1
	fi
	if "${h}"; then
		startWebpack
	fi
	if "${o}"; then
		open "http://localhost:${WHR_PORT}"
	fi

}

printStartUsage() {
	cat <<EOF
invalid option "$arg"
whr start
options:
--hot:		start hot reloading
--open:		open in browser
--reset:	wipe database and re-install core
EOF
}

startDocker() {
	# optionally rebuild (useful for reset)

	export WHR_PORT=""
	export PHPMYADMIN_PORT=""
	build=""
	[[ "$1" == '--build' ]] && build="--build"
	WHR_PORT="$(getWHRJsonPort)"
	# isContainerRunning && docker-compose down
	# cbeck that the port specified in whr.json is available
	if ! isDockerPortAvailable "$WHR_PORT"; then
		if
			! isContainerRunning ||
				(isContainerRunning && [[ "$(getDockerContainerPort)" != "$WHR_PORT" ]])
		then
			echo "❌ Unable to start container, port $WHR_PORT is already in use. You can set a different port in whr.json "
			exit 1
		fi
	fi
	# find an available port for phpmyadmin
	PHPMYADMIN_PORT="8180"
	echo "Using default phpMyAdmin port 8180"
	if ! isDockerPortAvailable "$PHPMYADMIN_PORT"; then
		echo "8180 unavailable... Finding an available port for phpMyAdmin"
		while ! isDockerPortAvailable "$PHPMYADMIN_PORT"; do
			((PHPMYADMIN_PORT++))
		done
	fi

	# start docker container  (to rebuild add --build flag)
	if ! docker compose up -d --wait --quiet-pull $build; then
		echo "Docker compose failed"
		exit 1
	fi
	# check if db exists and install
	if ! main wp core is-installed 2>/dev/null || [[ "$build" == 'build' ]]; then
		echo "Core installing now"
		sleep 2
		coreInstall || exit 1

	fi
	# update the wordpress / whr.json port if necessary
	updateWordpressPort "$WHR_PORT"
	# log to the user
	echo "✔️ Starting container: $(getDockerContainerName "wordpress")"
	echo "✔️ phpMyAdmin started at http://localhost:${PHPMYADMIN_PORT}"
	echo "✔️ Wordpress started at http://localhost:${WHR_PORT}"

}

startWebpack() {
	(
		cd "${PACKAGE_DIR}" || exit
		# enable webpack to access WORKING_DIR global
		export WORKING_DIR="$WORKING_DIR"
		npx webpack serve --config ./build/webpack.dev.js
	)
}

stop() {
	docker compose down
}

# Removes everything, containers, images, volumes
clean() {
	docker compose down --rmi all --volumes
}

# Stops and removes containers and deletes volumes
destroy() {
	docker compose rm --stop -v
}

reset() {
	docker compose down --volumes
}

openDockerInBrowser() {
	local port=""
	echo 'open please'
	port="$(getWHRJsonPort)"
	open "http://localhost:${port}"
}

# Installs wp database tables and resets theme
coreInstall() {
	local url
	local title
	url="localhost:$(getWHRJsonPort)"
	title="$WORKING_DIR_NAME"

	# remove any existing database
	main wp db clean --yes 2>/dev/null
	echo "wp core install --debug --url=$url --title=$title --admin_user='admin' --admin_password='password' --admin_email='admin@example.com'"
	if ! main wp core install --url="$url" --title="$title" --admin_user='admin' --admin_email='admin@example.com' --admin_password='password'; then
		echo "Failed to run wp core install"
		return 1
	fi
	# core install will reset to default theme. We need to sync whr.json theme to whatever theme it's using
	activeTheme="$(getActiveTheme)"
	echo "Resetting active theme in whr.json -> $activeTheme"
	updateWHRJsonTheme "$activeTheme"

	echo "Wordpress core installed"

}

build() {
	# 1. Build wp scripts asset files in public diretory
	# !!!Remember, this is running in your project directory, outside container
	buildWebpack || exit 1

	# 2. Build enqueue assets
	# !!!Remember, you are running this command inside the wordpress container
	buildEnqueueAssets || exit 1
}

# Build webpack
# but it outputs to the volume inside the container
buildWebpack() {
	cd vendor/aslamhus/wordpress-hmr || exit 1
	ls -1
	if ! npx wp-scripts build --webpack-src-dir="$WORKING_DIR/resources" --config build/webpack.prod.js; then
		echo "Failed to run wp-scripts build"
		exit 1
	fi
	cd "$WORKING_DIR"
}

# Build Enqueue Assets
buildEnqueueAssets() {
	if ! execContainer wordpress bash -c "php ../vendor/aslamhus/wordpress-hmr build.php"; then
		return 1
	fi
}

# run wp-cli in docker container
wp() {
	shift
	container=$(getDockerContainerName wpcli)
	[[ -z "$container" ]] && (
		echo "Failed to run wp-cli. Container name not found. Please start your container"
		exit 1
	)

	docker exec "${container}" wp "$@"
}

# execute commands in the wordpress container
execContainer() {
	shift
	container=$(getDockerContainerName wordpress)
	[[ -z "$container" ]] && (
		echo "Failed to run docker exec. Container name not found. Please start your container"
		exit 1
	)
	docker exec "${container}" "$@"
}

main "$@"
